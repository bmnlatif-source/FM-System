# Copy this file to `.env` and fill in the values from your Supabase project
# (dashboard → Project Settings → API). `.env` is gitignored — never commit it.

# Safe to ship in the browser build — protected by Row-Level Security.
VITE_SUPABASE_URL=https://noaocbyytzfuvscdwmga.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Admin key, used ONLY by local scripts (scripts/setup-supabase.mjs).
# NEVER put this in frontend code, chat, or version control.
SUPABASE_SERVICE_ROLE_KEY=
